---
import type { SiteContent } from "../content/site";
import Icon from "./Icon.astro";

interface Props {
  content: SiteContent;
}

const { content: t } = Astro.props;
---

<section id="services" class="relative border-b border-border py-16 sm:py-24 scroll-mt-16">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="max-w-2xl">
      <h2 class="font-heading text-3xl sm:text-4xl font-semibold uppercase text-ivory">
        {t.services.title}
      </h2>
      <p class="mt-4 text-muted leading-relaxed">{t.services.subtitle}</p>
    </div>

    <ul class="mt-12 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {
        t.services.items.map((item) => (
          <li class="group relative rounded-lg border border-border bg-surface p-6 hover:border-lime/50 transition-colors duration-200">
            <div class="flex items-start gap-4">
              <span class="flex items-center justify-center w-12 h-12 shrink-0 rounded-lg bg-surface-2 border border-border text-lime group-hover:bg-lime/10 group-hover:border-lime/40 transition-colors duration-200">
                <Icon name={item.icon} class="w-6 h-6" />
              </span>
              <div>
                <h3 class="font-heading text-lg font-semibold text-ivory uppercase tracking-wide">
                  {item.title}
                </h3>
                <p class="mt-2 text-sm text-muted leading-relaxed">{item.desc}</p>
              </div>
            </div>
          </li>
        ))
      }
    </ul>
  </div>
</section>
