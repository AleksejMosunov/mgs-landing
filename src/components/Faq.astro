---
import type { SiteContent } from "../content/site";

interface Props {
  content: SiteContent;
}

const { content: t } = Astro.props;
---

<section id="faq" class="relative border-b border-border bg-surface py-16 sm:py-24 scroll-mt-16">
  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
    <div class="max-w-2xl">
      <h2 class="font-heading text-3xl sm:text-4xl font-semibold uppercase text-ivory">
        {t.faq.title}
      </h2>
      <p class="mt-4 text-muted leading-relaxed">{t.faq.subtitle}</p>
    </div>

    <div class="mt-10 divide-y divide-border border-y border-border">
      {
        t.faq.items.map((item) => (
          <details class="group py-5">
            <summary class="focus-ring flex cursor-pointer list-none items-center justify-between gap-4 rounded font-heading font-semibold text-ivory">
              <span>{item.q}</span>
              <svg
                class="w-5 h-5 shrink-0 text-lime transition-transform duration-200 group-open:rotate-45"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                aria-hidden="true"
              >
                <path d="M12 5v14M5 12h14" />
              </svg>
            </summary>
            <p class="mt-3 text-sm sm:text-base text-muted leading-relaxed pr-8">{item.a}</p>
          </details>
        ))
      }
    </div>
  </div>
</section>
