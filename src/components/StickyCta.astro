---
import type { SiteContent } from "../content/site";
import { contactConst } from "../content/site";

interface Props {
  content: SiteContent;
}

const { content: t } = Astro.props;
---

<div
  class="lg:hidden fixed bottom-0 inset-x-0 z-40 border-t border-border bg-ink/95 backdrop-blur-md px-4 py-3 flex gap-3"
  style="padding-bottom: max(0.75rem, env(safe-area-inset-bottom));"
>
  <a
    href={contactConst.waLink}
    target="_blank"
    rel="noopener noreferrer"
    class="focus-ring flex-1 inline-flex items-center justify-center gap-2 rounded border border-border py-3 text-sm font-heading font-semibold uppercase text-ivory"
    aria-label={t.stickyCta.message}
  >
    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z" />
    </svg>
    {t.stickyCta.message}
  </a>
  <a
    href={`tel:${contactConst.phone1}`}
    class="focus-ring flex-1 inline-flex items-center justify-center gap-2 rounded bg-lime py-3 text-sm font-heading font-semibold uppercase text-ink"
  >
    <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z" />
    </svg>
    {t.stickyCta.call}
  </a>
</div>
<div class="lg:hidden h-16" aria-hidden="true"></div>
