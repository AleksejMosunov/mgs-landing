---
import type { SiteContent } from "../content/site";

interface Props {
  content: SiteContent;
}

const { content: t } = Astro.props;
---

<section id="process" class="relative border-b border-border py-16 sm:py-24 scroll-mt-16">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="max-w-2xl">
      <h2 class="font-heading text-3xl sm:text-4xl font-semibold uppercase text-ivory">
        {t.process.title}
      </h2>
      <p class="mt-4 text-muted leading-relaxed">{t.process.subtitle}</p>
    </div>

    <ol class="mt-12 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {
        t.process.steps.map((step, i) => (
          <li class="relative rounded-lg border border-border bg-surface p-6">
            <span class="font-display italic text-4xl text-lime/40">{String(i + 1).padStart(2, "0")}</span>
            <h3 class="mt-3 font-heading font-semibold text-ivory uppercase tracking-wide">{step.title}</h3>
            <p class="mt-2 text-sm text-muted leading-relaxed">{step.desc}</p>
            {i < t.process.steps.length - 1 && (
              <svg
                class="hidden lg:block absolute top-1/2 -right-4 w-4 h-4 -translate-y-1/2 text-border"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M9 6l6 6-6 6" />
              </svg>
            )}
          </li>
        ))
      }
    </ol>
  </div>
</section>
