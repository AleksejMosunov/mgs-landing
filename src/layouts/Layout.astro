---
import "../styles/global.css";
import { contactConst, type SiteContent } from "../content/site";

interface Props {
  content: SiteContent;
  ogImage?: string;
}

const { content: t, ogImage = "/og-image.jpg" } = Astro.props;

const site = Astro.site ?? new URL("https://mgs.pp.ua");
const currentPath = Astro.url.pathname;

const canonicalUrl = new URL(currentPath, site).toString();
const ruUrl = new URL("/ru/", site).toString();
const ukUrl = new URL("/", site).toString();

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "AutoRepair",
  "@id": `${site.origin}/#business`,
  name: "MGS Автосервіс",
  image: new URL(ogImage, site).toString(),
  url: site.origin,
  telephone: contactConst.phone1,
  priceRange: "$$",
  address: {
    "@type": "PostalAddress",
    streetAddress: "вул. Жоліо Кюрі, 53",
    addressLocality: "Одеса",
    addressCountry: "UA",
  },
  geo: {
    "@type": "GeoCoordinates",
    latitude: contactConst.lat,
    longitude: contactConst.lng,
  },
  openingHoursSpecification: [
    {
      "@type": "OpeningHoursSpecification",
      dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"],
      opens: "09:00",
      closes: "19:00",
    },
  ],
  sameAs: [contactConst.tgLink],
  areaServed: {
    "@type": "City",
    name: "Одеса",
  },
  aggregateRating: {
    "@type": "AggregateRating",
    ratingValue: "4.9",
    reviewCount: "210",
  },
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: t.faq.items.map((item) => ({
    "@type": "Question",
    name: item.q,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.a,
    },
  })),
};
---

<!doctype html>
<html lang={t.htmlLang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />

    <title>{t.meta.title}</title>
    <meta name="description" content={t.meta.description} />
    <meta name="keywords" content={t.meta.keywords} />
    <meta name="author" content="MGS Автосервіс" />
    <meta name="theme-color" content="#05060a" />

    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="ru" href={ruUrl} />
    <link rel="alternate" hreflang="uk" href={ukUrl} />
    <link rel="alternate" hreflang="x-default" href={ukUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="MGS Автосервіс" />
    <meta property="og:title" content={t.meta.title} />
    <meta property="og:description" content={t.meta.description} />
    <meta property="og:image" content={new URL(ogImage, site).toString()} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:locale" content={t.locale === "ru" ? "ru_UA" : "uk_UA"} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={t.meta.title} />
    <meta name="twitter:description" content={t.meta.description} />
    <meta name="twitter:image" content={new URL(ogImage, site).toString()} />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />
    <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} is:inline />
  </head>
  <body class="bg-ink text-ivory font-body antialiased selection:bg-lime selection:text-ink">
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-3 focus:left-3 focus:z-[100] focus:bg-lime focus:text-ink focus:px-4 focus:py-2 focus:rounded font-heading font-semibold"
    >
      {t.locale === "ru" ? "Перейти к содержимому" : "Перейти до вмісту"}
    </a>
    <slot />
  </body>
</html>

<style is:global>
  ::-webkit-scrollbar {
    width: 10px;
  }
  ::-webkit-scrollbar-track {
    background: var(--color-ink);
  }
  ::-webkit-scrollbar-thumb {
    background: var(--color-surface-3);
    border-radius: 999px;
  }
</style>
